# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434

# Models — PLAYER_MODEL falls back to GAME_MASTER_MODEL if unset
GAME_MASTER_MODEL=qwen3:14b
PLAYER_MODEL=qwen3.5:2b-mlx

# Temperatures — GM creates the world (more creative), players act on it (more deterministic)
GAME_MASTER_TEMPERATURE=0.9
PLAYER_TEMPERATURE=0.3

# Dataset generation (benchmark/generate_dataset.py)
HARD_MODE=false
NUM_ROOMS=4
CHAIN_DEPTH=5
GEN_MAX_ATTEMPTS=6
