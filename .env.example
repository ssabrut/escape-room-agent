# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434

# Models — PLAYER_MODEL and SOLVER_MODEL fall back to BUILDER_MODEL if unset
BUILDER_MODEL=qwen3:14b
PLAYER_MODEL=qwen3.5:2b-mlx
# Solver agent (agents.solver_agent) — its own model, independent of generation
SOLVER_MODEL=qwen3.5:2b-mlx

# Inference tuning
# OLLAMA_KEEP_ALIVE: how long the model stays resident ("-1" = never unload, fastest)
# OLLAMA_NUM_PREDICT: max tokens per call (lower to cap a model that runs away)
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_PREDICT=4096

# OLLAMA_WORKERS: comma-separated base URLs of additional Ollama instances
# (e.g. another Mac on the LAN running BUILDER_MODEL/STORYBOARD_MODEL). When set,
# independent LLM calls within a generation step — puzzle_builder's per-room
# theming calls and the storyboard's beats/flavor passes — are split round-robin
# across this machine's local Ollama and each of these, generated concurrently.
# Leave unset to run everything against OLLAMA_BASE_URL.
# (OLLAMA_THEMING_WORKERS is accepted as a legacy alias.)
#
# Run ./scripts/setup_ollama_worker.sh on each additional Mac (advertises its
# Ollama instance via Bonjour/mDNS), then ./scripts/setup_main.sh on this
# machine with no arguments to auto-discover and fill this in.
# OLLAMA_WORKERS=http://192.168.1.50:11434

# Temperatures — builder creates the world (creative), players/solver act (deterministic)
BUILDER_TEMPERATURE=0.9
PLAYER_TEMPERATURE=0.3
SOLVER_TEMPERATURE=0.2

# Dataset generation (benchmark/generate_dataset.py)
HARD_MODE=true
NUM_ROOMS=4
CHAIN_DEPTH=5
GEN_MAX_ATTEMPTS=3

# API authentication
API_KEY=84beec4c-8d7d-44fa-be4d-15ff630b8fa8

# Pixel-art sprite generation
# SPRITE_WORKERS: comma-separated base URLs of remote sprite workers
# (run `uvicorn sprite_worker:app --host 0.0.0.0 --port 8001` on each).
# Sprite jobs are split round-robin between this machine's local pipeline
# and each remote worker, generated concurrently. Leave unset to generate
# everything locally. Add as many workers as you have machines for.
#
# Run ./scripts/setup_main.sh with no arguments to auto-discover all workers
# on the LAN via Bonjour/mDNS and fill this in automatically.
# SPRITE_WORKERS=http://192.168.1.50:8001,http://192.168.1.51:8001
