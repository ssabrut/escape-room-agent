# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434

# Models — PLAYER_MODEL falls back to GAME_MASTER_MODEL if unset
GAME_MASTER_MODEL=qwen3:14b
PLAYER_MODEL=qwen3.5:2b-mlx

# Inference tuning
# OLLAMA_KEEP_ALIVE: how long the model stays resident ("-1" = never unload, fastest)
# OLLAMA_NUM_PREDICT: max tokens per call (lower to cap a model that runs away)
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_PREDICT=4096

# Temperatures — GM creates the world (more creative), players act on it (more deterministic)
GAME_MASTER_TEMPERATURE=0.9
PLAYER_TEMPERATURE=0.3

# Dataset generation (benchmark/generate_dataset.py)
HARD_MODE=true
NUM_ROOMS=4
CHAIN_DEPTH=5
GEN_MAX_ATTEMPTS=3
