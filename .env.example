# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434

# Models — PLAYER_MODEL falls back to GAME_MASTER_MODEL if unset
GAME_MASTER_MODEL=qwen3.5:9b-mlx
PLAYER_MODEL=qwen3.5:9b-mlx

# Temperatures — GM creates the world (more creative), players act on it (more deterministic)
GAME_MASTER_TEMPERATURE=0.8
PLAYER_TEMPERATURE=0.3
